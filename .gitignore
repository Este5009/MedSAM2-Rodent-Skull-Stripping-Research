# Python bytecode and caches
__pycache__/
*.pyc
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo

# Local data, model weights, and generated runtime artifacts
datasets/*
!datasets/.gitkeep
# Pre-existing local dataset locations
Image_Database/
Mask_Database/
# Upstream repositories and their contents
external/
checkpoints/*
!checkpoints/.gitkeep
outputs/predictions/*
!outputs/predictions/.gitkeep
outputs/logs/*
!outputs/logs/.gitkeep
*.pth
*.pt
*.ckpt

# Medical imaging data
*.nii
*.nii.gz
*.nrrd
*.dcm

# Tabular experiment outputs
*.csv
*.xlsx

# Generated images
*.png
*.jpg

# Documentation and required figure placeholder remain trackable
!docs/**
!outputs/figures/.gitkeep

# Build and packaging artifacts
build/
dist/
*.egg-info/

# Temporary files, notebook caches, and operating-system metadata
*.tmp
*.temp
*.bak
~$*
.ipynb_checkpoints/
.DS_Store
Thumbs.db
Desktop.ini
